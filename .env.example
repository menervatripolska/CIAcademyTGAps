# ─── ОБЯЗАТЕЛЬНО ─────────────────────────────────────────────────────────
# Telegram бот: получи в @BotFather → /newbot (или /token для существующего)
BOT_TOKEN=123456:ABCDEF...

# Твой Telegram numeric id (узнать можно боту написать /id)
ADMIN_ID=5376892021

# ─── УЖЕ ЗАДАНЫ ПО УМОЛЧАНИЮ (можно не трогать) ──────────────────────────
# URL мини-аппа
WEBAPP_URL=https://menervatripolska.github.io/CIAcademyTGAps/

# Ссылка на курс (показывается принятым)
COURSE_URL=https://ciacademy.kz

# ─── ОПЦИОНАЛЬНО ─────────────────────────────────────────────────────────
# Airtable Personal Access Token — если хочешь красивую базу вместо SQLite.
# Без него всё работает: бот пишет в локальную SQLite, админу доступна
# команда /export (CSV в DM).
# Как получить: https://airtable.com/create/tokens
#   Scope: data.records:write + data.records:read
#   Access: CIAcademy Course Catalog
# AIRTABLE_API_KEY=patXXX.XXX
# AIRTABLE_BASE_ID=appa0lbQ8SuQvc7aV
# AIRTABLE_TABLE_ID=tblpPcaIPEfVswjnK

# Путь к SQLite файлу — по умолчанию /data/applicants.db (если есть volume),
# иначе ./applicants.db (локально рядом с ботом).
# DB_PATH=/data/applicants.db
